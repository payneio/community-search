# community-search environment configuration
#
# Resolution order: environment variable > .env > default
# Copy this file to .env and adjust values as needed.
# .env is gitignored; .env.example is tracked.

COMMUNITY_SEARCH_BIND_ADDR=127.0.0.1
COMMUNITY_SEARCH_PORT=8080
COMMUNITY_SEARCH_DATA_DIR=./data
# COMMUNITY_SEARCH_ADMIN_TOKEN=

RUST_LOG=community_search=info,tower_http=warn
